{
  "routes": [
    {
      "src": "/tips/([^/]+)/?",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot).*"
        }
      ],
      "dest": "/api/tips/share?slug=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/share/tips/([^/]+)/?",
      "dest": "/api/tips/share?slug=$1"
    },
    {
      "src": "/api/tips/([^/]+)/share/?",
      "dest": "/api/tips/share?slug=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://locsang-be.cgnn.vn/api/$1"
    },
    {
      "src": "/(.*\\..*)",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
